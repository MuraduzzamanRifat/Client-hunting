# === SMTP Configuration ===
# Add multiple inboxes as comma-separated values
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@yourdomain.com
SMTP_PASS=app-password-here

# Multiple sender inboxes (rotate automatically)
# Format: email:password,email2:password2
SENDER_INBOXES=inbox1@domain.com:pass1,inbox2@domain.com:pass2,inbox3@domain2.com:pass3

# === Search API (optional, falls back to DuckDuckGo) ===
SERPAPI_KEY=

# === AI Personalization ===
# Supports: anthropic, openai
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Sending Limits ===
DAILY_LIMIT_PER_INBOX=20
DELAY_BETWEEN_EMAILS=60
# Warmup period in days (sends fewer emails during this time)
WARMUP_DAYS=7
