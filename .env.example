# Serper.dev — https://serper.dev (2,500 free credits)
SERPER_API_KEY=your_serper_api_key_here

# ── Email / SMTP Settings ───────────────────────────────────────────
# Works with ANY email provider. Set your SMTP details below.
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_password_or_app_password
EMAIL_FROM=                           # optional: leave blank to use EMAIL_USER

# SMTP server settings — common providers:
#
#   Provider        SMTP_SERVER              PORT   SSL
#   ─────────────── ──────────────────────── ────── ─────
#   Gmail           smtp.gmail.com           587    false
#   Outlook/Hotmail smtp.office365.com       587    false
#   Yahoo           smtp.mail.yahoo.com      587    false
#   Zoho            smtp.zoho.com            587    false
#   Custom webmail  mail.yourdomain.com      465    true
#
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=false

# Google Sheets — service account credentials JSON file
# Guide: Google Cloud Console → APIs → Sheets API → Service Account → Download JSON
GOOGLE_CREDS_FILE=credentials.json

# ── Scheduler Settings (for 24/7 automation) ─────────────────────────
# Comma-separated keywords and locations for automated runs
SCHEDULE_KEYWORD=cafes,restaurants
SCHEDULE_LOCATION=Key West Florida,Miami Florida
SCHEDULE_COUNT=20
SCHEDULE_HOURS=6
SCHEDULE_SEND_EMAILS=false
